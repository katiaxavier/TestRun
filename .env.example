# Usado pelo docker-compose.yml (variáveis de substituição)

# Postgres
POSTGRES_USER=testrun
POSTGRES_PASSWORD=testrun
POSTGRES_DB=testrun

# OAuth 2.0 (3LO) da Atlassian — ver instruções no README para registrar o app
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
JIRA_CLOUD_ID=

# Chave para cifrar tokens em repouso (AES-256-GCM, 32 bytes em base64)
# Gerar com: openssl rand -base64 32
TOKEN_ENC_KEY=

# Segredo para assinar a sessão (JWT httpOnly)
SESSION_JWT_SECRET=

FRONTEND_URL=http://localhost:5173
