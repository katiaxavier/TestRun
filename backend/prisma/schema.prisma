datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String              @id @default(uuid())
  atlassianAccountId String              @unique
  email              String?
  displayName        String
  avatarUrl          String?
  accessToken        String?
  refreshToken       String?
  accessTokenExpires DateTime?
  memberships        ProjectMembership[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Project {
  id             String              @id @default(uuid())
  jiraProjectId  String              @unique
  jiraProjectKey String              @unique
  name           String
  lastSyncedAt   DateTime?
  boards         Board[]
  suites         Suite[]
  batches        ExecutionBatch[]
  memberships    ProjectMembership[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model Board {
  id          String           @id @default(uuid())
  jiraBoardId String           @unique
  name        String
  type        String
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suites      Suite[]
  batches     ExecutionBatch[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProjectMembership {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lastCheckedAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Suite {
  id          String      @id @default(uuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  boards      Board[]
  jiraKey     String?
  manualKey   String?
  title       String
  isManual    Boolean     @default(false)
  epicKey     String?
  epicSummary String?
  testCases   TestCase[]
  executions  Execution[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([projectId, jiraKey])
  @@unique([projectId, manualKey])
}

model TestCase {
  id                 String              @id @default(uuid())
  jiraKey            String
  title              String
  link               String?
  priority           String?
  automated          Boolean             @default(false)
  suiteId            String
  suite              Suite               @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  executionTestCases ExecutionTestCase[]
  scenarioTemplates  TestCaseScenario[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model TestCaseScenario {
  id         String     @id @default(uuid())
  testCaseId String
  testCase   TestCase   @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  name       String
  scenarios  Scenario[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Execution {
  id            String              @id @default(uuid())
  suiteId       String?
  suite         Suite?              @relation(fields: [suiteId], references: [id])
  batchId       String?
  batch         ExecutionBatch?     @relation(fields: [batchId], references: [id])
  sprint        String
  version       String
  startDate     DateTime
  endDate       DateTime
  testedFeature String?
  responsible   String
  status        String              @default("IN_PROGRESS")
  testCases     ExecutionTestCase[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([createdAt])
}

model ExecutionBatch {
  id                  String      @id @default(uuid())
  projectId           String
  project             Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  boardId             String?
  board               Board?      @relation(fields: [boardId], references: [id], onDelete: SetNull)
  name                String?
  suiteIds            Json
  testedFeature       String?
  status              String      @default("IN_PROGRESS")
  excludedTestCaseIds Json        @default("[]")
  executions          Execution[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model ExecutionTestCase {
  id             String     @id @default(uuid())
  executionId    String
  execution      Execution  @relation(fields: [executionId], references: [id], onDelete: Cascade)
  testCaseId     String
  testCase       TestCase   @relation(fields: [testCaseId], references: [id], onDelete: Restrict)
  status         String     @default("PENDING")
  originalStatus String?
  responsible    String?
  comments       String?
  issues         Issue[]
  scenarios      Scenario[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Scenario {
  id                  String            @id @default(uuid())
  executionTestCaseId String
  executionTestCase   ExecutionTestCase @relation(fields: [executionTestCaseId], references: [id], onDelete: Cascade)
  templateId          String?
  template            TestCaseScenario? @relation(fields: [templateId], references: [id])
  name                String
  status              String            @default("PENDING")
  comments            String?
  issues              Issue[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Issue {
  id                  String             @id @default(uuid())
  executionTestCaseId String?
  executionTestCase   ExecutionTestCase? @relation(fields: [executionTestCaseId], references: [id], onDelete: Cascade)
  scenarioId          String?
  scenario            Scenario?          @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  type                String
  jiraKey             String?
  title               String
  severity            String?
  jiraPriority        String?
  jiraLabels          String[]           @default([])
  status              String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}
